<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>刑法學術論文整理</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+TC:wght@300;400;500;700;900&family=Noto+Sans+TC:wght@300;400;500&family=Playfair+Display:ital,wght@0,700;1,400&display=swap" rel="stylesheet">
<style>
  /* ════════════════════════════════════════════════════
     MORANDI PALETTE
  ════════════════════════════════════════════════════ */
  :root {
    --ink:        #3d3530;
    --parchment:  #f0ece6;
    --gold:       #8a7560;
    --gold-light: #b0997e;
    --red:        #9b6f6f;
    --gray:       #7a7370;
    --gray-light: #e6e1da;
    --line:       #ccc5bb;
    --white:      #f7f4f0;
    --green:      #5a7268;
    --green-bg:   #edf2ef;
    --blue:       #5b6e7c;
    --blue-bg:    #edf0f3;
  }

  /* ════════════════════════════════════════════════════
     RESET
  ════════════════════════════════════════════════════ */
  * { margin:0; padding:0; box-sizing:border-box; }
  body { font-family:'Noto Sans TC',sans-serif; background:var(--parchment); color:var(--ink); }

  /* ════════════════════════════════════════════════════
     HEADER
  ════════════════════════════════════════════════════ */
  .site-header {
    background:var(--ink);
    padding:14px 24px;
    display:flex;
    align-items:center;
    justify-content:space-between;
    border-bottom:3px solid var(--gold);
    gap:12px;
    flex-wrap:wrap;
  }
  .site-title { font-family:'Noto Serif TC',serif; font-size:1rem; font-weight:500; color:var(--parchment); letter-spacing:.12em; }
  .site-subtitle { font-size:.68rem; color:var(--gold-light); letter-spacing:.22em; margin-top:2px; }
  .header-badge { font-size:.66rem; color:var(--gold); letter-spacing:.15em; border:1px solid var(--gold); padding:4px 10px; white-space:nowrap; }

  /* ════════════════════════════════════════════════════
     SEARCH
  ════════════════════════════════════════════════════ */
  .search-wrap { position:relative; }
  .search-box {
    background:rgba(255,255,255,.08); border:1px solid rgba(184,134,11,.35);
    color:var(--parchment); font-family:'Noto Sans TC',sans-serif;
    font-size:.78rem; padding:6px 30px 6px 12px; width:180px;
    letter-spacing:.06em; outline:none; transition:all .25s;
  }
  .search-box::placeholder { color:#6b6356; }
  .search-box:focus { border-color:var(--gold); background:rgba(255,255,255,.12); width:220px; }
  .search-icon { position:absolute; right:9px; top:50%; transform:translateY(-50%); color:var(--gold); font-size:.85rem; pointer-events:none; }
  .search-results-overlay { display:none; position:fixed; inset:0; background:rgba(26,18,8,.7); z-index:999; backdrop-filter:blur(3px); }
  .search-results-panel {
    display:none; position:fixed; top:50%; left:50%; transform:translate(-50%,-50%);
    background:var(--white); width:min(680px,92vw); max-height:75vh; overflow-y:auto;
    z-index:1000; border-top:4px solid var(--red); box-shadow:0 20px 60px rgba(0,0,0,.35);
  }
  .search-results-header { display:flex; align-items:center; justify-content:space-between; padding:16px 22px 12px; border-bottom:1px solid var(--line); }
  .search-results-title { font-family:'Noto Serif TC',serif; font-size:.92rem; font-weight:700; letter-spacing:.08em; }
  .search-close-btn { background:none; border:none; font-size:1.4rem; color:var(--gray); cursor:pointer; line-height:1; }
  .search-close-btn:hover { color:var(--red); }
  .search-result-item { padding:14px 22px; border-bottom:1px solid var(--gray-light); cursor:pointer; transition:background .15s; display:block; }
  .search-result-item:hover { background:var(--parchment); }
  .search-result-author { font-size:.66rem; letter-spacing:.18em; color:var(--red); margin-bottom:3px; }
  .search-result-title { font-family:'Noto Serif TC',serif; font-size:.92rem; font-weight:700; line-height:1.5; margin-bottom:5px; }
  .search-result-snippet { font-size:.76rem; color:var(--gray); line-height:1.7; }
  .search-result-kw { display:inline-block; font-size:.62rem; background:var(--gray-light); color:var(--gray); padding:2px 6px; margin:2px 2px 0; letter-spacing:.06em; }
  .search-highlight { background:#fff3cd; color:#856404; font-weight:600; }
  .search-empty { padding:32px; text-align:center; color:var(--gray); font-size:.84rem; letter-spacing:.1em; }
  .search-count { font-size:.7rem; color:var(--gray); letter-spacing:.12em; }

  /* ════════════════════════════════════════════════════
     AUTHOR TAB RAIL
  ════════════════════════════════════════════════════ */
  .authors-rail {
    background:var(--ink); padding:0 24px;
    display:flex; border-bottom:1px solid #2e2820;
    overflow-x:auto; -webkit-overflow-scrolling:touch;
    scrollbar-width:none;
  }
  .authors-rail::-webkit-scrollbar { display:none; }
  .author-tab {
    font-family:'Noto Serif TC',serif; font-size:.8rem; color:#8a7e6e;
    padding:11px 18px; letter-spacing:.08em; cursor:pointer;
    border-bottom:3px solid transparent; transition:all .2s;
    white-space:nowrap; display:flex; align-items:center; gap:6px; flex-shrink:0;
  }
  .author-tab:hover { color:var(--gold-light); }
  .author-tab.active { color:var(--gold); border-bottom-color:var(--gold); }
  .author-tab .dot { width:5px; height:5px; border-radius:50%; background:var(--gold); opacity:0; transition:opacity .2s; }
  .author-tab.active .dot { opacity:1; }

  /* ════════════════════════════════════════════════════
     MAIN LAYOUT  — 上下排列
  ════════════════════════════════════════════════════ */
  .main { display:flex; flex-direction:column; }

  /* ── 教授橫條（上方） ── */
  .prof-bar {
    background:var(--white);
    border-bottom:1px solid var(--line);
    position:relative;
    padding:16px 24px;
    display:flex;
    align-items:center;
    gap:20px;
    flex-wrap:wrap;
  }
  .prof-bar::before {
    content:''; position:absolute; top:0; left:0; right:0; height:3px;
    background:linear-gradient(90deg,var(--red) 0%,var(--gold) 60%,transparent 100%);
  }

  /* 頭像 */
  .prof-portrait {
    width:64px; height:64px; border-radius:50%; flex-shrink:0;
    background:var(--ink); border:2px solid var(--gold);
    overflow:hidden; display:flex; align-items:center; justify-content:center;
  }
  .prof-portrait img { width:100%; height:100%; object-fit:cover; object-position:top; }
  .prof-portrait-initial { font-family:'Noto Serif TC',serif; font-size:1.5rem; color:var(--gold); font-weight:700; }

  /* 姓名 */
  .prof-identity { flex-shrink:0; min-width:90px; }
  .prof-name-zh { font-family:'Noto Serif TC',serif; font-size:1.15rem; font-weight:700; letter-spacing:.06em; }
  .prof-name-en { font-family:'Playfair Display',serif; font-style:italic; font-size:.74rem; color:var(--gray); margin-top:2px; }

  /* 資訊欄 */
  .prof-meta {
    display:flex; flex-direction:column; gap:4px;
    padding-left:20px; border-left:1px solid var(--line);
    flex:1; min-width:160px;
  }
  .prof-info-row { display:flex; gap:8px; align-items:baseline; }
  .prof-info-label { font-size:.62rem; letter-spacing:.14em; color:var(--gold); font-weight:500; min-width:30px; flex-shrink:0; }
  .prof-info-value { font-size:.76rem; color:var(--ink); line-height:1.5; }

  /* 關鍵詞 */
  .prof-tags { min-width:140px; }
  .prof-tags-label { font-size:.6rem; letter-spacing:.15em; color:var(--gold); margin-bottom:5px; }
  .tag-list { display:flex; flex-wrap:wrap; gap:4px; }
  .tag {
    font-size:.62rem; letter-spacing:.08em; border:1px solid var(--line);
    color:var(--gray); padding:2px 8px; background:var(--gray-light);
    transition:all .18s; cursor:pointer;
  }
  .tag:hover, .tag.active { border-color:var(--red); color:var(--red); background:#fdf0f0; }

  /* 篇數 */
  .prof-count { flex-shrink:0; margin-left:auto; background:var(--ink); padding:10px 18px; text-align:center; }
  .prof-count-num { font-family:'Playfair Display',serif; font-size:2rem; color:var(--gold); line-height:1; }
  .prof-count-label { font-size:.6rem; color:#8a7e6e; letter-spacing:.18em; margin-top:2px; }

  /* ── 爭點卡列表區（下方） ── */
  .cards-area { padding:24px 20px 40px; }

  /* ════════════════════════════════════════════════════
     爭點卡
  ════════════════════════════════════════════════════ */
  .section-header { display:flex; align-items:center; margin-bottom:20px; }
  .section-title {
    font-family:'Noto Serif TC',serif; font-size:1rem; font-weight:400;
    letter-spacing:.08em; display:flex; align-items:center; gap:8px;
    color:var(--gray);
  }
  .section-title::before { content:''; display:block; width:3px; height:18px; background:var(--red); }

  .article-card {
    background:var(--white); border:1px solid var(--line);
    margin-bottom:12px; cursor:pointer; transition:all .2s;
    position:relative; overflow:hidden; animation:fadeUp .3s ease both;
  }
  .article-card::before {
    content:''; position:absolute; left:0; top:0; bottom:0; width:3px;
    background:var(--red); transform:scaleY(0); transition:transform .2s; transform-origin:bottom;
  }
  .article-card:hover::before, .article-card.expanded::before { transform:scaleY(1); }
  .article-card:hover { border-color:var(--gold-light); box-shadow:3px 3px 0 var(--line); transform:translate(-1px,-1px); }
  .article-card.expanded { border-color:var(--red); transform:none; box-shadow:none; }

  .card-header { padding:16px 18px; display:grid; grid-template-columns:1fr auto; gap:12px; align-items:start; }
  .card-meta { display:flex; align-items:center; gap:8px; margin-bottom:6px; flex-wrap:wrap; }
  .card-journal { font-size:.65rem; letter-spacing:.12em; color:var(--red); font-weight:500; }
  .card-year { font-size:.65rem; color:var(--gray); letter-spacing:.08em; }
  .card-dot { color:var(--line); }
  .card-title-zh { font-family:'Noto Serif TC',serif; font-size:1rem; font-weight:700; line-height:1.65; letter-spacing:.04em; margin-bottom:4px; }
  .card-title-en { font-family:'Playfair Display',serif; font-style:italic; font-size:.72rem; color:var(--gray); }
  .card-keywords { display:flex; flex-wrap:wrap; gap:4px; margin-top:8px; }
  .keyword { font-size:.62rem; letter-spacing:.08em; color:var(--gray); border:1px solid var(--line); padding:1px 7px; }
  .card-toggle {
    width:26px; height:26px; border:1px solid var(--line);
    display:flex; align-items:center; justify-content:center;
    color:var(--gray); font-size:1rem; flex-shrink:0; margin-top:2px; transition:all .2s;
  }
  .article-card.expanded .card-toggle { background:var(--red); border-color:var(--red); color:white; transform:rotate(45deg); }

  /* ── 卡片主體 ── */
  .card-body { max-height:0; overflow:hidden; transition:max-height .45s ease; }
  .card-body.open { max-height:9999px; }

  .body-tabs { display:flex; border-bottom:1px solid var(--line); background:var(--white); overflow-x:auto; scrollbar-width:none; }
  .body-tabs::-webkit-scrollbar { display:none; }
  .body-tab {
    font-size:.7rem; letter-spacing:.12em; padding:10px 16px; cursor:pointer;
    color:var(--gray); border-bottom:2px solid transparent; transition:all .18s;
    white-space:nowrap; flex-shrink:0;
  }
  .body-tab:hover { color:var(--ink); }
  .body-tab.active { color:var(--red); border-bottom-color:var(--red); font-weight:500; }

  .tab-panel { display:none; padding:22px 18px; }
  .tab-panel.active { display:block; }

  /* ── 摘要 ── */
  .abstract-text { font-size:.86rem; line-height:2.1; color:#3a3228; letter-spacing:.02em; }
  .abstract-text strong { color:var(--ink); }
  .abstract-text em { color:var(--red); font-style:normal; font-weight:500; }

  /* ── 爭點區塊 ── */
  .issue-block { border:1px solid var(--line); margin-bottom:20px; background:var(--white); overflow:hidden; }
  .issue-header { background:var(--ink); padding:10px 16px; display:flex; align-items:center; gap:10px; flex-wrap:wrap; }
  .issue-num { font-family:'Playfair Display',serif; font-size:.68rem; color:#f0ece6; border:1px solid var(--gold); padding:2px 8px; letter-spacing:.08em; flex-shrink:0; }
  .issue-title { font-family:'Noto Serif TC',serif; font-size:.88rem; color:var(--parchment); font-weight:500; letter-spacing:.03em; line-height:1.55; }

  /* 學說行 — 手機預設堆疊，桌機雙欄 */
  .doctrine-item { border-bottom:1px solid var(--gray-light); padding:16px 16px; }
  .doctrine-item:last-child { border-bottom:none; }
  .doctrine-label { display:flex; align-items:center; flex-wrap:wrap; gap:8px; margin-bottom:10px; }
  .doctrine-badge {
    display:inline-flex; align-items:center; font-size:.66rem;
    letter-spacing:.08em; padding:3px 9px; font-weight:500; flex-shrink:0;
  }
  .badge-main { background:var(--blue-bg);  color:var(--blue);  border-left:3px solid var(--blue); }
  .badge-alt  { background:var(--gray-light); color:#4a4035;    border-left:3px solid #9b8f7e; }
  .badge-crit { background:#fff5f5;           color:var(--red);  border-left:3px solid var(--red); }
  .doctrine-who { font-size:.67rem; color:var(--gray); letter-spacing:.04em; line-height:1.5; }
  .doctrine-content { font-size:.84rem; line-height:2.05; color:#3a3228; }
  .doctrine-content strong { color:var(--ink); }
  .doctrine-content em { color:var(--red); font-style:normal; font-weight:500; }
  .doctrine-sub { margin-top:10px; padding:10px 14px; border-left:3px solid var(--line); font-size:.77rem; color:var(--gray); line-height:1.95; background:#f5f2ed; }
  .doctrine-sub em { color:var(--red); font-style:normal; }

  /* 作者結論框 */
  .author-conclusion { background:var(--green-bg); border:1px solid #a8c4b0; border-left:4px solid var(--green); padding:14px 16px; margin:4px 16px 16px; }
  .conclusion-label { font-size:.65rem; letter-spacing:.18em; color:var(--green); font-weight:500; margin-bottom:7px; }
  .conclusion-text { font-size:.83rem; line-height:2.05; color:#1a3a25; }
  .conclusion-text strong { color:var(--green); }
  .conclusion-text em { color:#c0392b; font-style:normal; font-weight:500; }

  /* 目次 */
  .toc-l1 { display:flex; gap:10px; padding:9px 0; border-bottom:1px dotted var(--line); align-items:flex-start; }
  .toc-l1:last-child { border-bottom:none; }
  .toc-l1-num { font-family:'Playfair Display',serif; font-size:.78rem; color:var(--red); font-weight:700; min-width:18px; flex-shrink:0; padding-top:2px; }
  .toc-l1-text { font-family:'Noto Serif TC',serif; font-size:.85rem; font-weight:500; line-height:1.65; }
  .toc-l2 { padding:3px 0 3px 0; display:flex; gap:7px; font-size:.78rem; color:var(--gray); line-height:1.65; }
  .toc-l2-num { min-width:20px; flex-shrink:0; }
  .toc-l3 { padding:2px 0 2px 20px; font-size:.74rem; color:#9b8f7e; line-height:1.75; display:block; }
  .toc-l4 { padding:2px 0 2px 14px; font-size:.7rem; color:#b0a090; line-height:1.75; display:block; }

  /* 卡片底欄 */
  .card-footer { padding:11px 16px; background:var(--ink); display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:8px; }
  .doi-text { font-size:.63rem; color:#8a7e6e; letter-spacing:.08em; }
  .doi-val { color:var(--gold-light); }
  .read-btn {
    font-size:.65rem; letter-spacing:.14em; color:var(--gold); border:1px solid var(--gold);
    padding:5px 12px; cursor:pointer; background:transparent; transition:all .18s;
    text-decoration:none; display:inline-block; flex-shrink:0;
  }
  .read-btn:hover { background:var(--gold); color:var(--ink); }

  .ornament { text-align:center; color:var(--line); font-size:1rem; letter-spacing:.4em; margin:24px 0 6px; }

  @keyframes fadeUp { from{opacity:0;transform:translateY(12px)} to{opacity:1;transform:translateY(0)} }

  /* ════════════════════════════════════════════════════
     DESKTOP ≥ 768px — 稍微加大
  ════════════════════════════════════════════════════ */
  @media (min-width: 768px) {
    .site-header { padding:16px 40px; }
    .prof-bar { padding:20px 40px; gap:24px; }
    .prof-portrait { width:76px; height:76px; }
    .prof-name-zh { font-size:1.25rem; }
    .prof-meta { padding-left:24px; }
    .cards-area { padding:28px 40px 48px; }
    .card-header { padding:20px 22px; }
    .card-title-zh { font-size:1.05rem; }
    .tab-panel { padding:28px 24px; }
    /* 桌機：學說行雙欄 */
    .doctrine-item { display:grid; grid-template-columns:180px 1fr; gap:18px; align-items:start; padding:20px 22px; }
    .doctrine-label { margin-bottom:0; flex-direction:column; align-items:flex-start; }
    .author-conclusion { padding:16px 20px; margin:4px 20px 20px; }
    .issue-block { margin-bottom:26px; }
  }

  @media (min-width: 1200px) {
    .prof-bar { padding:20px 60px; }
    .cards-area { padding:32px 60px 56px; max-width:1100px; }
    .card-title-zh { font-size:1.08rem; }
  }

</style>
</head>
<body>

<header class="site-header">
  <div>
    <div class="site-title">刑法學術論文整理庫</div>
    <div class="site-subtitle">CRIMINAL LAW ACADEMIC ARCHIVE</div>
  </div>
  <div class="search-wrap">
    <input class="search-box" id="globalSearch" type="text" placeholder="搜尋論文、關鍵詞、爭點…" oninput="doSearch(this.value)" onfocus="if(this.value.length>0)showResults()" autocomplete="off">
    <span class="search-icon">🔍</span>
  </div>
</header>
<div class="search-results-overlay" id="searchOverlay" onclick="closeSearch()"></div>
<div class="search-results-panel" id="searchPanel">
  <div class="search-results-header">
    <span class="search-results-title">搜尋結果</span>
    <button class="search-close-btn" onclick="closeSearch()">✕</button>
  </div>
  <div id="searchResultsList"></div>
</div>

<nav class="authors-rail">
  <div class="author-tab active" onclick="switchAuthor('chou',this)"><span class="dot"></span>周漾沂</div>
  <div class="author-tab" onclick="switchAuthor('tsai',this)"><span class="dot"></span>蔡聖偉</div>
  <div class="author-tab" onclick="switchAuthor('xue',this)"><span class="dot"></span>薛智仁</div>
  <div class="author-tab" onclick="switchAuthor('hsu',this)"><span class="dot"></span>許恒達</div>
  <div class="author-tab" onclick="switchAuthor('hsu2',this)"><span class="dot"></span>徐育安</div>
  <div class="author-tab" onclick="switchAuthor('wang',this)"><span class="dot"></span>王皇玉</div>
  <div class="author-tab" style="opacity:.4;cursor:default">＋ 待新增</div>
</nav>

<!-- AUTHOR: chou -->
<div class="main author-panel" id="panel-chou">
  <div class="prof-bar">
    <div class="prof-portrait">
      <img src="https://www.law.ntu.edu.tw/media/k2/items/cache/f7b9be29873ad525695063e6e748eae3_M.jpg" alt="周漾沂教授"
           onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"/>
      <span class="prof-portrait-initial" style="display:none">周</span>
    </div>
    <div class="prof-identity">
      <div class="prof-name-zh">周漾沂</div>
      <div class="prof-name-en">Yang-Yi Chou</div>
    </div>
    <div class="prof-meta">
      <div class="prof-info-row"><span class="prof-info-label">職稱</span><span class="prof-info-value">教授</span></div>
      <div class="prof-info-row"><span class="prof-info-label">單位</span><span class="prof-info-value">臺灣大學法律學院</span></div>
      <div class="prof-info-row"><span class="prof-info-label">領域</span><span class="prof-info-value">刑法總則、未遂犯理論、法哲學</span></div>
    </div>
    <div class="prof-tags">
      <div class="prof-tags-label">關鍵詞篩選</div>
      <div class="tag-list"><span class="tag active" onclick="filterTag(this,'all')">全部</span>
        <span class="tag" onclick="filterTag(this,'未遂')">未遂</span>
        <span class="tag" onclick="filterTag(this,'中止')">中止</span>
        <span class="tag" onclick="filterTag(this,'著手')">著手實行</span>
        <span class="tag" onclick="filterTag(this,'風險')">風險輸出</span></div>
    </div>
    <div class="prof-count">
      <div class="prof-count-num">2</div>
      <div class="prof-count-label">篇　論　文</div>
    </div>
  </div>

  <div class="cards-area">    <div class="section-header">
      <div class="section-title">論文列表</div>
      
    </div>

    <!-- ══ CARD 1 ══ -->
    <div class="article-card" id="card-1" data-tags="未遂 中止 著手 風險" onclick="toggleCard('card-1',event)">
      <div class="card-header">
        <div>
          <div class="card-meta">
            <span class="card-journal">月旦法學雜誌</span>
            <span class="card-dot">·</span>
            <span class="card-year">No.345 ／ 2024.2</span>
          </div>
          <div class="card-title-zh">論未了未遂中止之成立可能性</div>
